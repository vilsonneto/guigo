{
  "name": "guigo",
  "private": true,
  "description": "Bot WhatsApp que calcula quanto do faturamento diário é livre pra gastar",
  "author": {
    "name": "Vilson Padilha Neto",
    "url": "https://github.com/vilsonneto"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vilsonneto/guigo.git"
  },
  "bugs": {
    "url": "https://github.com/vilsonneto/guigo/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "turbo run dev --filter=@guigo/bot",
    "dev:admin": "turbo run dev --filter=@guigo/admin",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "db:test": "node --env-file=.env --import=tsx scripts/test-conexao.ts",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "supabase": "^2.77.0",
    "turbo": "^2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20"
  }
}
