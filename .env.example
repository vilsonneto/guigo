# Supabase (bot)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# Supabase (admin - Next.js precisa do prefixo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=xxx
EVOLUTION_INSTANCE=guigo

# Configuracao do motorista
MOTORISTA_WHATSAPP=5551999999999
GASOLINA_DIARIA=120

# Webhook (porta do servidor HTTP do bot — Railway define PORT automaticamente)
PORT=3001
WEBHOOK_URL=http://host.docker.internal:3001/webhook
